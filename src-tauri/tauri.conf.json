{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSPro-Ltd Corp",
  "version": "0.1.3",
  "identifier": "com.mspro-ltd.corp",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @msproltd/ui dev",
    "beforeBuildCommand": "pnpm --filter @msproltd/ui build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MSPro-Ltd Corp",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCNEJBRkEwNzMxMTg2RUQKUldUdGhoRnpvSzlMSy9Ka0pDOGZMc1lGU3B1Nk5iM0VTUVAySDZMdFROK041ZjJiK2pWYndHQ0kK",
      "endpoints": [
        "https://github.com/vladimirspecalp-hub/MSPro-Ltd-Corp/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
