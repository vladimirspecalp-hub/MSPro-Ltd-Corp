{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the MSPro-Ltd Corp main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "msiexec",
          "cmd": "msiexec.exe",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
